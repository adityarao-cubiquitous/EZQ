rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRootRestaurantBranchAdmin(restaurantBranchId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.restaurantBranchId == restaurantBranchId
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive == true;
    }

    function isActiveRestaurantBranch(restaurantBranchId) {
      return exists(/databases/$(database)/documents/restaurantBranches/$(restaurantBranchId))
        && get(/databases/$(database)/documents/restaurantBranches/$(restaurantBranchId)).data.isActive == true;
    }

    function isCustomerJoinCounterCreate(businessDate) {
      return request.resource.data.keys().hasOnly([
          'businessDate',
          'lastTokenNumber',
          'updatedAt'
        ])
        && request.resource.data.businessDate == businessDate
        && request.resource.data.lastTokenNumber == 1
        && request.resource.data.updatedAt == request.time;
    }

    function isCustomerJoinCounterIncrement(businessDate) {
      return request.resource.data.keys().hasOnly([
          'businessDate',
          'lastTokenNumber',
          'updatedAt'
        ])
        && request.resource.data.businessDate == resource.data.businessDate
        && request.resource.data.businessDate == businessDate
        && request.resource.data.lastTokenNumber is int
        && request.resource.data.lastTokenNumber == resource.data.lastTokenNumber + 1
        && request.resource.data.updatedAt == request.time;
    }

    function isOwnPhoneCustomerProfile(customerId) {
      return isSignedIn()
        && request.auth.uid == customerId
        && request.resource.data.uid == customerId
        && request.resource.data.phone == request.auth.token.phone_number
        && request.resource.data.authProvider == 'phone'
        && request.resource.data.appInstalled == true
        && request.resource.data.keys().hasOnly([
          'uid',
          'phone',
          'authProvider',
          'appInstalled',
          'firstName',
          'lastName',
          'displayName',
          'profileCompletedAt',
          'createdAt',
          'updatedAt'
        ]);
    }

    function isOwnDebugPhoneCustomerProfile(customerId) {
      return isSignedIn()
        && request.auth.uid == customerId
        && request.auth.token.firebase.sign_in_provider == 'anonymous'
        && request.resource.data.uid == customerId
        && request.resource.data.phone is string
        && request.resource.data.authProvider == 'debug_phone'
        && request.resource.data.appInstalled == true
        && request.resource.data.keys().hasOnly([
          'uid',
          'phone',
          'authProvider',
          'appInstalled',
          'firstName',
          'lastName',
          'displayName',
          'profileCompletedAt',
          'createdAt',
          'updatedAt'
        ]);
    }

    match /customers/{customerId} {
      allow read: if isSignedIn() && request.auth.uid == customerId;
      allow create: if isOwnPhoneCustomerProfile(customerId)
        || isOwnDebugPhoneCustomerProfile(customerId);
      allow update: if (isOwnPhoneCustomerProfile(customerId)
        || isOwnDebugPhoneCustomerProfile(customerId))
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      match /visits/{visitId} {
        allow read: if isSignedIn() && request.auth.uid == customerId;
        allow write: if false;
      }
    }

    match /admins/{adminUserId} {
      allow read: if isSignedIn() && request.auth.uid == adminUserId;
      allow update: if isSignedIn()
        && request.auth.uid == adminUserId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'onboardingCompleted',
          'onboardedAt'
        ])
        && request.resource.data.restaurantBranchId == resource.data.restaurantBranchId;
      allow create, delete: if false;
    }

    match /restaurantBranches/{restaurantBranchId} {
      allow read: if resource.data.isActive == true
        || isRootRestaurantBranchAdmin(restaurantBranchId);
      allow update: if isRootRestaurantBranchAdmin(restaurantBranchId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'onboardingCompleted',
          'floorCount',
          'totalTables',
          'totalSeats',
          'capacityTypes',
          'updatedAt'
        ]);
      allow create, delete: if false;

      match /floors/{floorId} {
        allow read: if isRootRestaurantBranchAdmin(restaurantBranchId);
        allow create, update: if isRootRestaurantBranchAdmin(restaurantBranchId);
        allow delete: if false;
      }

      match /tables/{tableId} {
        allow read: if true;
        allow create, update: if isRootRestaurantBranchAdmin(restaurantBranchId);
        allow delete: if false;
      }

      match /settings/{settingsId} {
        allow read: if isRootRestaurantBranchAdmin(restaurantBranchId);
        allow create, update: if isRootRestaurantBranchAdmin(restaurantBranchId);
        allow delete: if false;
      }

      match /queueEntries/{queueEntryId} {
        allow read: if true;
        allow create: if isActiveRestaurantBranch(restaurantBranchId)
          && request.resource.data.status == 'waiting'
          && request.resource.data.customerName is string
          && request.resource.data.phone is string
          && request.resource.data.partySize is int;
        allow update: if isActiveRestaurantBranch(restaurantBranchId)
          || isRootRestaurantBranchAdmin(restaurantBranchId);
        allow delete: if false;
      }

      match /dailyCounters/{businessDate} {
        allow read: if isRootRestaurantBranchAdmin(restaurantBranchId)
          || isActiveRestaurantBranch(restaurantBranchId);
        allow create: if isRootRestaurantBranchAdmin(restaurantBranchId)
          || (isActiveRestaurantBranch(restaurantBranchId)
            && isCustomerJoinCounterCreate(businessDate));
        allow update: if isRootRestaurantBranchAdmin(restaurantBranchId)
          || (isActiveRestaurantBranch(restaurantBranchId)
            && isCustomerJoinCounterIncrement(businessDate));
        allow delete: if false;
      }
    }

    match /{path=**}/queueEntries/{queueEntryId} {
      allow read: if true;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
